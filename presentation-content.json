      "label": "CHROME LAUNCH",
      "title": "Launch Chrome for Debugging",
      "language": "json",
      "code": "{\n  \"name\": \"Chrome: Launch\",\n  \"type\": \"chrome\",\n  \"request\": \"launch\",\n  \"url\": \"http://localhost:5173\",\n  \"webRoot\": \"${workspaceFolder}/src\",\n  \"sourceMaps\": true,\n  \"preLaunchTask\": \"npm: dev\",\n  \"runtimeArgs\": [\n    \"--disable-web-security\"\n  ]\n}",
      "tags": [
        { "text": "Chrome" },
        { "text": "Launch" }
      ]
    },
    {
      "type": "code",
      "bg": "dark",
      "label": "CHROME ATTACH",
      "title": "Attach to Running Chrome",
      "language": "json",
      "code": "{\n  \"name\": \"Chrome: Attach\",\n  \"type\": \"chrome\",\n  \"request\": \"attach\",\n  \"port\": 9222,\n  \"url\": \"http://localhost:5173\",\n  \"webRoot\": \"${workspaceFolder}/src\",\n  \"sourceMaps\": true\n}\n\n/* Start Chrome with remote debugging:\n   chrome --remote-debugging-port=9222 */",
      "tags": [
        { "text": "Chrome" },
        { "text": "Attach" }
