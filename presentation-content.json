    {
      "type": "content",
      "bg": "light",
      "label": "ATTACH VS LAUNCH",
      "title": "Why Attach > Launch?",
      "body": "For complex managed environments, Attach is superior:",
      "bullets": [
        "Debug processes you didn't start",
        "Works with uv, docker, docker-compose",
        "No need to modify your run commands",
        "Attach to already-running processes",
        "Debug production-like environments"
      ]
    },
    {
      "type": "terminal",
      "bg": "muted",
      "label": "DEBUGPY SETUP",
      "title": "Starting FastAPI with debugpy",
      "lines": [
        { "type": "prompt", "text": "# Install debugpy" },
        { "type": "output", "text": "uv add --dev debugpy" },
        { "type": "prompt", "text": "# Run with debugpy listening on port 5678" },
        { "type": "output", "text": "uv run debugpy --listen 5678 --wait-for-client -m fastapi dev --port 8081" },
        { "type": "comment", "text": "# Alternative: Add to your code" },
        { "type": "prompt", "text": "import debugpy" },
        { "type": "output", "text": "debugpy.listen((\"0.0.0.0\", 5678))" }
