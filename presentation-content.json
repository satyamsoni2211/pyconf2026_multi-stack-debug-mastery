    {
      "type": "code",
      "bg": "dark",
      "label": "BACKGROUND TASKS",
      "title": "Using isBackground: true",
      "language": "json",
      "code": "{\n  \"label\": \"Start: Vite Dev Server\",\n  \"type\": \"shell\",\n  \"command\": \"npm run dev\",\n  \"isBackground\": true,\n  \"problemMatcher\": [\n    \"$tsc-watch\",\n    {\n      \"owner\": \"vite\",\n      \"pattern\": {\n        \"regexp\": \"^.*$\",\n        \"message\": 0\n      },\n      \"background\": {\n        \"activeOnStart\": true,\n        \"beginsPattern\": \".*VITE.*\",\n        \"endsPattern\": \".*ready in.*\"\n      }\n    }\n  ]\n}",
      "tags": [
        { "text": "isBackground" },
        { "text": "Vite" }
      ]
