      "type": "code",
      "bg": "dark",
      "label": "PYTHON FILE",
      "title": "Debug a Python File",
      "language": "json",
      "code": "{\n  \"name\": \"Python: Debug File\",\n  \"type\": \"debugpy\",\n  \"request\": \"launch\",\n  \"program\": \"${workspaceFolder}/main.py\",\n  \"console\": \"integratedTerminal\",\n  \"justMyCode\": true,\n  \"env\": {\n    \"DEBUG\": \"true\"\n  }\n}",
      "tags": [
        { "text": "launch.json" },
        { "text": "Python File" }
      ]
    },
    {
      "type": "code",
      "bg": "dark",
      "label": "PYTHON MODULE",
      "title": "Debug a Python Module",
      "language": "json",
      "code": "{\n  \"name\": \"Python: Module\",\n  \"type\": \"debugpy\",\n  \"request\": \"launch\",\n  \"module\": \"fastapi\",\n  \"args\": [\n    \"dev\",\n    \"--port\", \"8080\"\n  ],\n  \"cwd\": \"${workspaceFolder}/backend\",\n  \"console\": \"integratedTerminal\",\n  \"justMyCode\": true\n}",
      "tags": [
