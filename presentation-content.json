    {
      "type": "code",
      "bg": "dark",
      "label": "NODE DEBUG",
      "title": "Debug Node.js Application",
      "language": "json",
      "code": "{\n  \"name\": \"Node: Launch\",\n  \"type\": \"node\",\n  \"request\": \"launch\",\n  \"program\": \"${workspaceFolder}/server/index.js\",\n  \"console\": \"integratedTerminal\",\n  \"runtimeExecutable\": \"node\",\n  \"skipFiles\": [\"<node_internals>/**\"]\n}\n\n{\n  \"name\": \"Node: Nodemon\",\n  \"type\": \"node\",\n  \"request\": \"launch\",\n  \"runtimeExecutable\": \"nodemon\",\n  \"program\": \"${workspaceFolder}/server/index.js\",\n  \"console\": \"integratedTerminal\"\n}",
      "tags": [
        { "text": "Node.js" },
        { "text": "Server" }
