{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Order Processor",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/demos/order_processor.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Python Debugger: backend application",
      "type": "debugpy",
      "request": "launch",
      "module": "fastapi",
      "args": ["dev", "--port", "8081"],
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": false
    },
    {
      "name": "Python Debugger: Attach using Process Id",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "port": 5678,
        "host": "127.0.0.1"
      },
        "justMyCode": false,
    "pathMappings": [
        
    ]
    },
    {
        "name": "Launch Program: node",
        "program": "user_manager.js",
        "request": "launch",
        "skipFiles": [
            "<node_internals>/**"
        ],
        "type": "node",
        "cwd": "${workspaceFolder}/demos"
    },
    {
      "name": "Launch Chrome",
      "request": "launch",
      "type": "chrome",
      "url": "http://localhost:5173",
      "runtimeExecutable": "/Applications/Opera.app/Contents/MacOS/Opera",
      "webRoot": "${workspaceFolder}/frontend",
      "sourceMapPathOverrides": {
        "/src/*": "${workspaceFolder}/frontend/src/*" 
    },
    "preLaunchTask": "Run fastapi backend server"
  }
  ]
}
