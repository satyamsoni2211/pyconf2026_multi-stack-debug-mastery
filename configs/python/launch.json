/**
 * Python Debug Configurations
 *
 * Part 1 & Part 3 of the workshop:
 * - Launch configurations for debugging Python applications
 * - Remote Attach pattern for debugpy
 * - Module-based debugging for FastAPI
 *
 * Usage: Copy these to .vscode/launch.json or include via "configurations" property
 */

{
  "version": "0.2.0",
  "configurations": [
    // =========================================================================
    // 1. Python – Remote Attach via debugpy (Primary config for workshop)
    //
    // Part 3: The Remote Attach Pattern
    // Assumes FastAPI is already running under debugpy (via task or manual start).
    //
    // Key settings:
    //   • connect.port  – must match the --listen port passed to debugpy
    //   • pathMappings  – maps local source to remote process path
    //   • justMyCode    – skip debugging library code
    // =========================================================================
    {
      "name": "Python: Remote Attach (debugpy)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "${workspaceFolder}/backend"
        }
      ],
      "justMyCode": true
    },

    // =========================================================================
    // 2. Python – Launch FastAPI directly (Part 1 exercise)
    //
    // Simplest debugging: VS Code launches the process directly.
    // Does NOT integrate with `uv run` but good for simple scripts.
    //
    // Use to understand difference between "Launch" and "Attach".
    // =========================================================================
    {
      "name": "Python: Launch FastAPI (direct)",
      "type": "debugpy",
      "request": "launch",
      "module": "fastapi",
      "args": ["dev", "--host", "0.0.0.0", "--port", "8080"],
      "cwd": "${workspaceFolder}/backend",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      }
    },

    // =========================================================================
    // 3. Python – Debug a single file
    //
    // For standalone Python scripts.
    // =========================================================================
    {
      "name": "Python: Debug File",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/${fileBasename}",
      "console": "integratedTerminal",
      "justMyCode": true
    },

    // =========================================================================
    // 4. Python – Debug pytest tests
    //
    // Run and debug pytest test suite.
    // =========================================================================
    {
      "name": "Python: Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "-s"
      ],
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      }
    },

    // =========================================================================
    // 5. Python – Debug with custom port (for Docker/remote)
    //
    // Use when debugging containers or remote processes.
    // =========================================================================
    {
      "name": "Python: Remote Attach (custom port)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5679
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/app"
        }
      ],
      "justMyCode": true
    }
  ]
}
