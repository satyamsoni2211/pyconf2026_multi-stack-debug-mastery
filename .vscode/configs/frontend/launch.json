/**
 * Frontend Debug Configurations
 *
 * Part 4 of the workshop:
 * - Chrome debugging for Vite frontend
 * - Electron debugging for desktop apps
 * - Node.js debugging for backend JavaScript
 *
 * Usage: Copy these to .vscode/launch.json or include via "configurations" property
 */

{
  "version": "0.2.0",
  "configurations": [
    // =========================================================================
    // 1. Chrome – Debug Vite Frontend (Primary workshop config)
    //
    // Part 4: Launch Chrome pointed at Vite dev server.
    // Set breakpoints in src/*.js directly in VS Code.
    //
    // Key settings:
    //   • url           – your frontend dev server URL
    //   • webRoot       – path to source files for source maps
    //   • preLaunchTask – ensures Vite server is running first
    // =========================================================================
    {
      "name": "Chrome: Debug Frontend",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/audient-frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*"
      },
      "preLaunchTask": "Start: Vite Dev Server"
    },

    // =========================================================================
    // 2. Chrome – Attach to running Chrome instance
    //
    // For debugging Chrome that's already open.
    // Start Chrome with: chrome --remote-debugging-port=9222
    // =========================================================================
    {
      "name": "Chrome: Attach",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/audient-frontend/src",
      "sourceMaps": true
    },

    // =========================================================================
    // 3. Electron – Debug Main Process (Bonus)
    //
    // Debug Electron main process under Node.js debugger.
    // Set breakpoints in electron/main.cjs for window creation, IPC, etc.
    //
    // Key settings:
    //   • runtimeExecutable – path to Electron binary
    //   • program           – entry point for main process
    //   • env.VITE_DEV_SERVER_URL – tell Electron where to find dev server
    // =========================================================================
    {
      "name": "Electron: Debug Main Process",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/audient-frontend/node_modules/.bin/electron",
      "runtimeArgs": ["--remote-debugging-port=9223"],
      "program": "${workspaceFolder}/audient-frontend/electron/main.cjs",
      "cwd": "${workspaceFolder}/audient-frontend",
      "env": {
        "VITE_DEV_SERVER_URL": "http://localhost:5173"
      },
      "preLaunchTask": "Start: Vite Dev Server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/audient-frontend/electron/**/*.js"]
    },

    // =========================================================================
    // 4. Electron – Debug Renderer Process
    //
    // Debug the web content inside Electron.
    // Uses Chrome debugger attached to Electron's renderer.
    // =========================================================================
    {
      "name": "Electron: Debug Renderer",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/audient-frontend/src",
      "runtimeExecutable": "${workspaceFolder}/audient-frontend/node_modules/.bin/electron"
    },

    // =========================================================================
    // 5. Node.js – Debug backend JavaScript/TypeScript
    //
    // For debugging Node.js servers (Express, etc.).
    // =========================================================================
    {
      "name": "Node.js: Launch Server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/audient-frontend/server/index.js",
      "console": "integratedTerminal",
      "runtimeExecutable": "node",
      "skipFiles": ["<node_internals>/**"]
    },

    // =========================================================================
    // 6. Node.js – Debug with Nodemon (auto-reload)
    //
    // For development with automatic restarts.
    // =========================================================================
    {
      "name": "Node.js: Nodemon",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "nodemon",
      "program": "${workspaceFolder}/audient-frontend/server/index.js",
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
